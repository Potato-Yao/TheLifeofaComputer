# Frontend
# No ports mapped to host anymore, access via external nginx on web_gateway
# FRONTEND_PORT=80

# Backend
# No ports mapped to host anymore
# BACKEND_PORT=8000

# Backend URL accessed by the frontend browser
# Empty means relative path (Nginx will proxy /api to backend)
FRONTEND_VITE_API_URL=

# Game Configs
STANDARD_MODE_DAYS=7

# Backend Configs
EVENTS_DIR=/app/data/events
